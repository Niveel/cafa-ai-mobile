{
  "expo": {
    "name": "Cafa AI",
    "slug": "cafa-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cafa-ai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.shopwit.cafaai",
      "associatedDomains": [
        "applinks:www.cafaai.com"
      ],
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow $(PRODUCT_NAME) to use your camera for avatar photos and chat attachments.",
        "NSPhotoLibraryUsageDescription": "Allow $(PRODUCT_NAME) to access your photo library for attachments and profile images.",
        "NSPhotoLibraryAddUsageDescription": "Allow $(PRODUCT_NAME) to save generated images and videos to your photo library.",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to access your microphone for speech-to-text and voice features.",
        "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to transcribe your speech into text prompts."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "softwareKeyboardLayoutMode": "resize",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.shopwit.cafaai",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "https",
              "host": "www.cafaai.com",
              "pathPrefix": "/billing"
            }
          ]
        },
        {
          "action": "VIEW",
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "cafa-ai",
              "host": "billing",
              "pathPrefix": "/success"
            },
            {
              "scheme": "cafa-ai",
              "host": "billing",
              "pathPrefix": "/cancel"
            },
            {
              "scheme": "cafa-ai",
              "pathPrefix": "/billing/success"
            },
            {
              "scheme": "cafa-ai",
              "pathPrefix": "/billing/cancel"
            }
          ]
        }
      ]
    },
    "androidStatusBar": {
      "translucent": false,
      "backgroundColor": "#ffffff"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for speech-to-text.",
          "speechRecognitionPermission": "Allow $(PRODUCT_NAME) to transcribe your speech into text."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos for chat attachments and avatar uploads.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to use your camera for captured attachments and profile photos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your media library.",
          "savePhotosPermission": "Allow $(PRODUCT_NAME) to save generated images and videos to your library.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to use your camera for media capture.",
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for video/audio capture.",
          "recordAudioAndroid": true
        }
      ],
      "expo-document-picker",
      "expo-video",
      "expo-audio",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f51ee322-7d82-43bd-a791-bd95e8e01363"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
